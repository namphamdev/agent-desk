{
  "name": "terminal-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --mode development && electrobun dev",
    "dev:hmr": "concurrently \"vite --port 5173\" \"vite build --mode development && electrobun dev\"",
    "dev:web": "vite --port 5173",
    "embed:win-icon": "node scripts/embed-win-icon.mjs",
    "build": "vite build && electrobun build",
    "build:canary": "vite build && electrobun build --env=canary",
    "build:stable": "vite build && electrobun build --env=stable",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@legendapp/list": "^3.3.2",
    "beautiful-mermaid": "^1.1.3",
    "diff": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.7.0",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/bun": "latest",
    "@types/diff": "^7.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electrobun": "^1.18.1",
    "highlight.js": "^11.10.0",
    "react-grab": "^0.1.48",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.0"
  }
}
